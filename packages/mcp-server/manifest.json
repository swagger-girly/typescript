{
  "dxt_version": "0.1",
  "name": "hello-world-testingggg-mcp",
  "version": "0.0.1-alpha.0",
  "description": "The official MCP Server for the Hello World Testingggg API",
  "author": {
    "name": "Hello World Testingggg",
    "email": "apiteam@swagger.io"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/swagger-girly/typescript.git"
  },
  "homepage": "https://github.com/swagger-girly/typescript/tree/main/packages/mcp-server#readme",
  "documentation": "http://swagger.io",
  "server": {
    "type": "node",
    "entry_point": "${__dirname}/index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/index.js"],
      "env": {
        "API_KEY": "${user_config.API_KEY}"
      }
    }
  },
  "user_config": {
    "API_KEY": {
      "title": "api_key",
      "description": "The API key for authorization in the header.",
      "required": true,
      "type": "string"
    }
  },
  "tools_generated": true,
  "compatibility": {
    "runtimes": {
      "node": ">=18.0.0"
    }
  },
  "keywords": ["api"]
}
